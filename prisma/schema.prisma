generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Guest {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MealSelection {
  id             String   @id @default(cuid())
  senderName     String
  attendeeName   String?
  adultMainDish  String
  /// Legacy: el formulario ya no pide menú infantil; nuevas filas guardan null.
  kidsMainDish   String?
  imageUrls      String[] @default([])
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LodgingRequest {
  id               String   @id @default(cuid())
  name             String
  numberOfPeople   Int
  adults           Int
  children         Int
  roomsNeeded      Int?
  roomBreakdown    String?  @db.Text
  arrivalDate      DateTime
  departureDate    DateTime
  willingToShare   Boolean  @default(false)
  nights           Int?
  estimatedTotal   Decimal? @db.Decimal(10, 2)
  paymentStatus    String   @default("pending")
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TransportInfo {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

model MakeupHairRequest {
  id          String   @id @default(cuid())
  name        String
  peopleCount Int
  serviceType String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Legacy: la web ya no sube fotos al servidor; el álbum es externo (Google Fotos). Tabla conservada por si hay datos antiguos.
model PhotoUpload {
  id           String   @id @default(cuid())
  uploaderName String?
  imageUrl     String
  createdAt    DateTime @default(now())
}
