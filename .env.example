# Base de datos PostgreSQL
# Opción A - PostgreSQL local (puerto 5432):
#   DATABASE_URL="postgresql://user:password@localhost:5432/wedding_landing?schema=public"
# Opción B - Base en la nube (sin instalar nada): crea una en https://neon.tech (gratis)
#   y pega aquí la connection string que te den (Connection string).
DATABASE_URL="postgresql://user:password@localhost:5432/wedding_landing?schema=public"

# Sitio privado: si defines SITE_PASSWORD, toda la web pedirá esta contraseña antes de entrar.
# Comparte solo con invitados. Si no la defines, la web es pública.
# SITE_PASSWORD="contraseña_para_invitados"

# Panel administrativo (login con JWT)
ADMIN_PASSWORD="cambiar_en_produccion"
# Secreto para firmar el JWT (mínimo 32 caracteres). Usar algo aleatorio y seguro.
ADMIN_JWT_SECRET="genera-un-secreto-de-al-menos-32-caracteres-aqui"

# Opcional: grupo de WhatsApp (link de invitación)
NEXT_PUBLIC_WHATSAPP_GROUP_LINK=""

# Opcional: URL base del sitio (para links en emails/QR)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Fotos de habitaciones: URLs de posts públicos de Facebook (separadas por coma). Se muestran en un carrusel embebido, sin descargar.
# Ejemplo: NEXT_PUBLIC_ROOM_PHOTOS_FACEBOOK_POST_URLS="https://www.facebook.com/.../posts/...,https://..."
NEXT_PUBLIC_ROOM_PHOTOS_FACEBOOK_POST_URLS=""

# Subida de imágenes: en producción usar Vercel Blob o Supabase Storage
# UPLOAD_STORAGE=local
# BLOB_READ_WRITE_TOKEN=  (si usas Vercel Blob)
