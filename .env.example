# Base de datos PostgreSQL
# Opción A - PostgreSQL local (puerto 5432):
#   DATABASE_URL="postgresql://user:password@localhost:5432/wedding_landing?schema=public"
# Opción B - Base en la nube (sin instalar nada): crea una en https://neon.tech (gratis)
#   y pega aquí la connection string que te den (Connection string).
DATABASE_URL="postgresql://user:password@localhost:5432/wedding_landing?schema=public"

# Sitio privado: define ambos para activar la puerta de contraseña. El middleware redirige a /acceso
# hasta que el invitado la introduzca. Requiere ADMIN_JWT_SECRET (≥32 caracteres) para firmar la cookie.
# - SITE_PASSWORD: la contraseña (solo servidor, usada por el API).
# - NEXT_PUBLIC_SITE_PROTECTED: el Edge Runtime no ve variables sin NEXT_PUBLIC_; este flag indica
#   que la protección está activa (no expone la contraseña). Sin ambos, la landing es pública.
# SITE_PASSWORD="tu_contraseña_para_invitados"
# NEXT_PUBLIC_SITE_PROTECTED="true"

# Panel administrativo (login con JWT)
ADMIN_PASSWORD="cambiar_en_produccion"
# Secreto para firmar el JWT (mínimo 32 caracteres). Usar algo aleatorio y seguro.
ADMIN_JWT_SECRET="genera-un-secreto-de-al-menos-32-caracteres-aqui"

# -----------------------------------------------------------------------------
# Landing pública (NEXT_PUBLIC_* = visibles en el navegador). Copia este bloque y ajusta por evento.
# Si omites una variable, se usa el valor por defecto definido en src/lib/constants.ts (SITE_DEFAULTS).
# -----------------------------------------------------------------------------

# Fecha del evento (ISO) y texto fijo en español (evita errores de hidratación por zona horaria)
NEXT_PUBLIC_EVENT_DATE_ISO="2026-04-25"
NEXT_PUBLIC_EVENT_DATE_DISPLAY_ES="25 de abril de 2026"
NEXT_PUBLIC_EVENT_NAME="Boda y Bautismo"
NEXT_PUBLIC_VENUE_NAME="Beach Club"

# Perfil Facebook del venue (fallback si no pones VENUE_PUBLIC_LINK)
NEXT_PUBLIC_VENUE_FB_LINK="https://www.facebook.com/profile.php?id=100067222092732&locale=es_LA"
# Opcional: web, Instagram u otro enlace del hotel. Vacío = se usa VENUE_FB_LINK.
# NEXT_PUBLIC_VENUE_PUBLIC_LINK=""

# Grupo de WhatsApp (invitación)
NEXT_PUBLIC_WHATSAPP_GROUP_LINK="https://chat.whatsapp.com/DKqJHVJHMOBKCnl2K0tBED"

